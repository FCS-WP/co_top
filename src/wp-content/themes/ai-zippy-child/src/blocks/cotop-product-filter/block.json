{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "ai-zippy/cotop-product-filter",
	"version": "1.0.0",
	"title": "CO-TOP Product Filter",
	"category": "ai-zippy",
	"icon": "filter",
	"description": "Sticky product category filter bar for CO-TOP product page.",
	"supports": { "html": false, "align": ["wide", "full"] },
	"attributes": {
		"items": {
			"type": "array",
			"default": [
				{ "label": "All Products", "target": "all" },
				{ "label": "Quartz Stone", "target": "quartz" },
				{ "label": "Solid Surface", "target": "solid" },
				{ "label": "Sintered Stone", "target": "sintered" },
				{ "label": "Care Guides", "target": "care" }
			]
		}
	},
	"textdomain": "ai-zippy",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"render": "file:./render.php",
	"viewScript": "file:./view.js"
}
