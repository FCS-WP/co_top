{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "ai-zippy/cotop-about",
	"version": "1.0.0",
	"title": "CO-TOP About",
	"category": "ai-zippy",
	"icon": "format-image",
	"description": "CO-TOP home story section with stacked images and badge.",
	"supports": {
		"html": false,
		"align": ["wide", "full"]
	},
	"attributes": {
		"label": { "type": "string", "default": "Our Story" },
		"title": { "type": "string", "default": "Crafting Singapore's\nFinest Surfaces" },
		"emphasis": { "type": "string", "default": "Since 1994" },
		"bodyOne": { "type": "string", "default": "With over three decades of expertise, CO-TOP Marketing has been helping homeowners, architects, and designers bring their visions to life through precision fabrication and premium surface materials." },
		"bodyTwo": { "type": "string", "default": "Our dedicated team handles every project with meticulous attention to detail — from sourcing globally to delivering flawless installations that stand the test of time." },
		"buttonText": { "type": "string", "default": "Learn About Us" },
		"buttonUrl": { "type": "string", "default": "/about" },
		"mainImageId": { "type": "number", "default": 0 },
		"mainImageUrl": { "type": "string", "default": "https://images.unsplash.com/photo-1556909172-54557c7e4fb7?w=900&q=80" },
		"insetImageId": { "type": "number", "default": 0 },
		"insetImageUrl": { "type": "string", "default": "https://images.unsplash.com/photo-1631889993959-41b4e9c6e3c5?w=400&q=80" },
		"badgeNumber": { "type": "string", "default": "30+" },
		"badgeLabel": { "type": "string", "default": "Years Experience" }
	},
	"textdomain": "ai-zippy",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"render": "file:./render.php"
}
